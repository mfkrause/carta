<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
$if(title)$
    <title>$title$</title>
$endif$
$if(date)$
    <dateModified>$date$</dateModified>
$endif$
$if(author)$
    <ownerName>$for(author)$$author$$sep$; $endfor$</ownerName>
$endif$
  </head>
  <body>
$body$
  </body>
</opml>
